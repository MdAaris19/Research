# Environment variables for Autonomous Research Agent System

# Storage settings
STORAGE_PATH=data/memory
OUTPUT_PATH=output

# API Keys (optional - for enhanced functionality)
OPENALEX_EMAIL=your_openalex_contact_email_here
CROSSREF_EMAIL=your_crossref_contact_email_here
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key_here
SPRINGER_META_API_KEY=your_springer_meta_api_key_here
SPRINGER_OPENACCESS_API_KEY=your_springer_openaccess_api_key_here
ELSEVIER_API_KEY=your_elsevier_api_key_here
ELSEVIER_INST_TOKEN=your_elsevier_institution_token_here
WILEY_API_KEY=your_wiley_api_key_here
PUBMED_API_KEY=your_pubmed_api_key_here

# Agent settings
MAX_PAPERS_PER_SOURCE=50
MAX_CONCURRENT_REQUESTS=5

# Processing settings
CLAIM_CONFIDENCE_THRESHOLD=0.5
CONTRADICTION_THRESHOLD=0.7

# Logging settings
LOG_LEVEL=INFO
LOG_FILE=research_system.log
